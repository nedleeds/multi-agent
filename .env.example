# ── LLM 서버 ──────────────────────────────────────────────────────────────

# 메인 오케스트레이터 — ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gpt-120b
OLLAMA_MAX_TOKENS=8000

# 서브에이전트 — vllm
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=google/gemma-3-27b-it
VLLM_API_KEY=token-abc123
VLLM_MAX_TOKENS=4000

# ── Jira ──────────────────────────────────────────────────────────────────
# Cloud:  https://your-domain.atlassian.net
# Server: https://jira.your-company.com
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=          # 특정 프로젝트로 검색 범위 제한 (선택)

# ── Bitbucket ─────────────────────────────────────────────────────────────
# BITBUCKET_TYPE: server (Data Center, 기본값) | cloud
BITBUCKET_TYPE=server
# Server: https://bitbucket.your-company.com
# Cloud:  https://api.bitbucket.org
BITBUCKET_BASE_URL=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=    # Server: personal access token / Cloud: app password
BITBUCKET_PROJECT_KEY=     # e.g. MYPROJ
BITBUCKET_REPO_SLUG=       # e.g. my-service (특정 레포 지정, 선택)

# ── Confluence ────────────────────────────────────────────────────────────
# Cloud:  https://your-domain.atlassian.net/wiki
# Server: https://confluence.your-company.com
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=      # 특정 스페이스로 검색 범위 제한 (선택)
