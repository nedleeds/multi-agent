# ═══════════════════════════════════════════════════════════════════════════
# LLM 배선 — main 은 OpenAI-compatible, sub 는 vLLM-계열 (아무 OpenAI-compat 서버)
# 환경 전환은 아래 값만 교체하면 끝. 코드 수정 불필요.
# ═══════════════════════════════════════════════════════════════════════════

# ── Main orchestrator (gpt-oss-120b) ──────────────────────────────────────
# 【Mac dev】OpenAI API 사용
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-oss-120b
OPENAI_API_KEY=sk-...
OPENAI_MAX_TOKENS=16000
OPENAI_TEMPERATURE=0.7

# 【사내 deploy】 로컬 gpt-oss 서버 — 위 4줄 주석 처리 후 아래 활성화
# OPENAI_BASE_URL=http://gpt-oss.internal.company.com/v1
# OPENAI_MODEL=gpt-oss-120b
# OPENAI_API_KEY=dummy
# OPENAI_MAX_TOKENS=16000

# ── Subagent (gemma / 또는 OpenAI-compat 아무 서버) ────────────────────────
# 【Mac dev】로컬 vLLM 또는 ollama — 원하는 쪽으로
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=google/gemma-3-27b-it
VLLM_API_KEY=token-abc123
VLLM_MAX_TOKENS=12000

# 【Mac dev 대안】 ollama 를 sub 로 쓰려면
# VLLM_BASE_URL=http://localhost:11434/v1
# VLLM_MODEL=qwen2.5:7b
# VLLM_API_KEY=ollama
# VLLM_MAX_TOKENS=8000

# 【사내 deploy】 gemma-4 vLLM 서버
# VLLM_BASE_URL=http://vllm.internal.company.com/v1
# VLLM_MODEL=google/gemma-4-27b-it
# VLLM_API_KEY=token-abc123
# VLLM_MAX_TOKENS=12000

# Qwen3 계열 쓸 때 thinking mode 억제 (기본 true)
# VLLM_DISABLE_THINKING=true

# ── Debug ─────────────────────────────────────────────────────────────────
# 모든 LLM 호출의 turn/model/msgs/tools/finish_reason/content 찍기
# AGENT_DEBUG=1

# ═══════════════════════════════════════════════════════════════════════════
# Jira (현장 이슈 조사용, 선택)
# ═══════════════════════════════════════════════════════════════════════════
# Cloud:  https://your-domain.atlassian.net
# Server: https://jira.your-company.com
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=          # 특정 프로젝트 제한 (선택)

# ═══════════════════════════════════════════════════════════════════════════
# Bitbucket (현장 이슈 조사용, 선택)
# ═══════════════════════════════════════════════════════════════════════════
BITBUCKET_TYPE=server                # server (Data Center) | cloud
# Server: https://bitbucket.your-company.com
# Cloud:  https://api.bitbucket.org
BITBUCKET_BASE_URL=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=              # Server: PAT / Cloud: app password
BITBUCKET_PROJECT_KEY=               # e.g. MYPROJ
BITBUCKET_REPO_SLUG=                 # e.g. my-service

# ═══════════════════════════════════════════════════════════════════════════
# Confluence (현장 이슈 조사용, 선택)
# ═══════════════════════════════════════════════════════════════════════════
# Cloud:  https://your-domain.atlassian.net/wiki
# Server: https://confluence.your-company.com
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=                # 특정 스페이스 제한 (선택)
